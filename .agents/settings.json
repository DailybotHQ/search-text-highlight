{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run eslint:check)",
      "Bash(npm run prettier:check)",
      "Bash(npm run eslint:fix)",
      "Bash(npm run prettier:fix)",
      "Bash(npm run build:tsc)",
      "Bash(npm run build)",
      "Bash(npm run build:dev)",
      "Bash(npm run test)",
      "Bash(npm run dev)",
      "Bash(npm run ncu:check)",
      "Bash(npm pack --dry-run)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git check-ignore:*)"
    ],
    "ask": [
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npm run ncu:upgrade)",
      "Bash(npm run release)",
      "Bash(npm publish:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.npmrc)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ]
  }
}
