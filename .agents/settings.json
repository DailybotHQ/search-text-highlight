{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(corepack pnpm run biome:check)",
      "Bash(corepack pnpm run biome:fix)",
      "Bash(corepack pnpm run biome:fix:unsafe)",
      "Bash(corepack pnpm run build:tsc)",
      "Bash(corepack pnpm run build)",
      "Bash(corepack pnpm run build:dev)",
      "Bash(corepack pnpm run build:types)",
      "Bash(corepack pnpm run test)",
      "Bash(corepack pnpm run test:watch)",
      "Bash(corepack pnpm run dev)",
      "Bash(corepack pnpm run ncu:check)",
      "Bash(corepack pnpm pack --dry-run)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git check-ignore:*)"
    ],
    "ask": [
      "Bash(corepack pnpm install:*)",
      "Bash(corepack pnpm install --frozen-lockfile)",
      "Bash(corepack pnpm run ncu:upgrade)",
      "Bash(corepack pnpm run release)",
      "Bash(corepack pnpm publish:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.npmrc)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ]
  }
}
